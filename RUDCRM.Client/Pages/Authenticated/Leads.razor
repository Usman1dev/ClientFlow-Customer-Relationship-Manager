@page "/leads"
@attribute [Authorize]
@inject LeadService LeadSvc
@inject IJSRuntime JS

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-funnel-fill me-2" style="color:var(--rud-secondary);"></i>Leads</h4>
    <button class="btn btn-rud btn-rud-primary" @onclick="ShowAdd"><i class="bi bi-plus-lg me-1"></i>Add Lead</button>
</div>
@if (_loading) { <LoadingSpinner /> } else {
<div class="data-card"><div class="data-card-body" style="overflow-x:auto;">
<table class="table-rud"><thead><tr><th>Contact</th><th>Company</th><th>Source</th><th>Status</th><th>Value</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var l in _leads) {
<tr>
    <td><div style="font-weight:600;">@l.ContactName</div><div style="font-size:.8rem;color:var(--rud-text-muted);">@l.Email</div></td>
    <td>@(l.Company ?? "—")</td>
    <td><span class="badge-status badge-contacted">@l.Source</span></td>
    <td><span class="badge-status badge-@l.Status.ToLower()">@l.Status</span></td>
    <td style="font-weight:600;">$@l.EstimatedValue.ToString("N0")</td>
    <td>
        <button class="btn btn-rud btn-rud-outline btn-rud-sm me-1" @onclick="() => ShowEdit(l)"><i class="bi bi-pencil"></i></button>
        <button class="btn btn-rud btn-rud-danger btn-rud-sm" @onclick="() => ConfirmDel(l)"><i class="bi bi-trash"></i></button>
    </td>
</tr>}
@if (!_leads.Any()) { <tr><td colspan="6" class="empty-state"><i class="bi bi-funnel"></i><p>No leads found</p></td></tr> }
</tbody></table></div></div>}

@if (_showModal) {
<div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content">
<div class="modal-header"><h5 class="modal-title">@(_isEdit?"Edit":"Add") Lead</h5><button class="btn-close" @onclick="()=>_showModal=false"></button></div>
<EditForm Model="_form" OnValidSubmit="Save"><DataAnnotationsValidator />
<div class="modal-body"><div class="row g-3">
<div class="col-md-6"><label class="form-label">Contact Name *</label><InputText @bind-Value="_form.ContactName" class="form-control" /><ValidationMessage For="()=>_form.ContactName" class="text-danger small" /></div>
<div class="col-md-6"><label class="form-label">Email *</label><InputText @bind-Value="_form.Email" class="form-control" /><ValidationMessage For="()=>_form.Email" class="text-danger small" /></div>
<div class="col-md-6"><label class="form-label">Phone</label><InputText @bind-Value="_form.Phone" class="form-control" /></div>
<div class="col-md-6"><label class="form-label">Company</label><InputText @bind-Value="_form.Company" class="form-control" /></div>
<div class="col-md-4"><label class="form-label">Source</label><InputSelect @bind-Value="_form.Source" class="form-select">
@foreach (var s in new[]{"Web","Referral","Social","Advertisement","Other"}){<option value="@s">@s</option>}</InputSelect></div>
<div class="col-md-4"><label class="form-label">Status</label><InputSelect @bind-Value="_form.Status" class="form-select">
@foreach (var s in new[]{"New","Contacted","Qualified","Lost","Converted"}){<option value="@s">@s</option>}</InputSelect></div>
<div class="col-md-4"><label class="form-label">Estimated Value ($)</label><InputNumber @bind-Value="_form.EstimatedValue" class="form-control" /></div>
<div class="col-12"><label class="form-label">Notes</label><InputTextArea @bind-Value="_form.Notes" class="form-control" rows="2" /></div>
</div></div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" @onclick="()=>_showModal=false">Cancel</button>
<button type="submit" class="btn btn-rud btn-rud-primary">@(_isEdit?"Update":"Create")</button></div>
</EditForm></div></div></div>}

<ConfirmDialog IsVisible="_showDel" Title="Delete Lead" Message="@($"Delete {_delTarget?.ContactName}?")" OnConfirm="Delete" OnCancel="()=>_showDel=false" />

@code {
    List<LeadDto> _leads=new(); LeadDto _form=new(); LeadDto? _delTarget;
    bool _loading=true,_showModal,_isEdit,_showDel;
    protected override async Task OnInitializedAsync(){_leads=await LeadSvc.GetAllAsync();_loading=false;}
    void ShowAdd(){_form=new();_isEdit=false;_showModal=true;}
    void ShowEdit(LeadDto l){_form=new(){Id=l.Id,ContactName=l.ContactName,Email=l.Email,Phone=l.Phone,Company=l.Company,Source=l.Source,Status=l.Status,EstimatedValue=l.EstimatedValue,Notes=l.Notes};_isEdit=true;_showModal=true;}
    void ConfirmDel(LeadDto l){_delTarget=l;_showDel=true;}
    async Task Save(){bool ok=_isEdit?await LeadSvc.UpdateAsync(_form.Id,_form):await LeadSvc.CreateAsync(_form);
        if(ok){await JS.InvokeVoidAsync("rudInterop.showToast",_isEdit?"Lead updated!":"Lead created!","success");_showModal=false;_leads=await LeadSvc.GetAllAsync();}
        else await JS.InvokeVoidAsync("rudInterop.showToast","Failed.","error");}
    async Task Delete(){if(_delTarget!=null){await LeadSvc.DeleteAsync(_delTarget.Id);_showDel=false;_leads=await LeadSvc.GetAllAsync();await JS.InvokeVoidAsync("rudInterop.showToast","Lead deleted.","success");}}
}
