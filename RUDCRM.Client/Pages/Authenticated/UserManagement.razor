@page "/user-management"
@attribute [Authorize(Roles = "Admin")]
@inject AdminService AdminSvc
@inject IJSRuntime JS

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-shield-lock-fill me-2" style="color:var(--rud-danger);"></i>User Management</h4>
</div>
@if(_loading){<LoadingSpinner/>}else{
<div class="data-card"><div class="data-card-body" style="overflow-x:auto;">
<table class="table-rud"><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
<tbody>@foreach(var u in _users){
<tr><td style="font-weight:600;">@u.FullName</td><td>@u.Email</td>
<td><span class="badge-status @(u.Role=="Admin"?"badge-urgent":"badge-qualified")">@u.Role</span></td>
<td><span class="badge-status @(u.IsActive?"badge-completed":"badge-lost")">@(u.IsActive?"Active":"Inactive")</span></td>
<td style="font-size:.85rem;">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
<td>
    @{ var userId = u.Id; }
    <select class="form-select form-select-sm d-inline-block" style="width:auto;margin-right:.5rem;" value="@u.Role"
            @onchange="(e) => HandleRoleChange(userId, e)">
        <option value="Admin">Admin</option><option value="Employee">Employee</option>
    </select>
    <button class="btn btn-rud btn-rud-sm @(u.IsActive?"btn-rud-danger":"btn-rud-primary")" @onclick="() => ToggleActive(userId)">
        @(u.IsActive?"Deactivate":"Activate")
    </button>
</td></tr>}</tbody></table></div></div>}

@code{
    List<UserDto> _users=new();bool _loading=true;
    protected override async Task OnInitializedAsync(){_users=await AdminSvc.GetAllUsersAsync();_loading=false;}

    async Task HandleRoleChange(string id, ChangeEventArgs e)
    {
        var role = e.Value?.ToString() ?? "Employee";
        var ok = await AdminSvc.UpdateRoleAsync(id, role);
        if(ok){await JS.InvokeVoidAsync("rudInterop.showToast","Role updated!","success");_users=await AdminSvc.GetAllUsersAsync();}
        else await JS.InvokeVoidAsync("rudInterop.showToast","Failed.","error");
    }

    async Task ToggleActive(string id){var ok=await AdminSvc.ToggleActiveAsync(id);
        if(ok){_users=await AdminSvc.GetAllUsersAsync();await JS.InvokeVoidAsync("rudInterop.showToast","User status updated.","success");}
    }
}
