@page "/about"
@layout RUDCRM.Client.Layout.MainLayout

<div style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);min-height:100vh;color:#fff;padding:4rem 0;">
    <div class="container">
        <div class="text-center mb-5 fade-in-up">
            <div class="auth-logo mx-auto">R</div>
            <h1 style="font-size:2.5rem;font-weight:800;">About RUD-CRM</h1>
            <p style="font-size:1.1rem;opacity:.8;max-width:600px;margin:1rem auto;">
                <strong>Relationship Understanding & Development</strong> — A modern CRM platform
                built for small businesses to manage their customer lifecycle efficiently.
            </p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4 fade-in-up delay-1">
                <div class="feature-card text-center h-100">
                    <div class="feature-icon mx-auto" style="background:rgba(99,102,241,.2);color:#818cf8;">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h5 style="font-weight:700;">Built with Blazor</h5>
                    <p style="font-size:.9rem;opacity:.7;">Powered by .NET 10 Blazor WebAssembly for a rich, interactive single-page application experience.</p>
                </div>
            </div>
            <div class="col-md-4 fade-in-up delay-2">
                <div class="feature-card text-center h-100">
                    <div class="feature-icon mx-auto" style="background:rgba(16,185,129,.2);color:#34d399;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 style="font-weight:700;">Secure Authentication</h5>
                    <p style="font-size:.9rem;opacity:.7;">ASP.NET Core Identity with JWT tokens and role-based authorization for Admin and Employee users.</p>
                </div>
            </div>
            <div class="col-md-4 fade-in-up delay-3">
                <div class="feature-card text-center h-100">
                    <div class="feature-icon mx-auto" style="background:rgba(14,165,233,.2);color:#38bdf8;">
                        <i class="bi bi-broadcast"></i>
                    </div>
                    <h5 style="font-weight:700;">Real-Time Updates</h5>
                    <p style="font-size:.9rem;opacity:.7;">SignalR-powered notifications and announcements for instant team communication.</p>
                </div>
            </div>
        </div>

        <div class="text-center fade-in-up delay-4">
            <h3 style="font-weight:700;">Technology Stack</h3>
            <div class="d-flex flex-wrap justify-content-center gap-3 mt-3">
                @foreach (var tech in new[] { "Blazor WASM", ".NET 10", "EF Core", "SQL Server", "SignalR", "Chart.js", "Bootstrap 5", "JWT Auth" })
                {
                    <span class="badge-status" style="background:rgba(255,255,255,.1);color:#fff;padding:.5rem 1rem;font-size:.85rem;">@tech</span>
                }
            </div>
            <p class="mt-4" style="opacity:.6;font-size:.85rem;">
                Developed as a semester project — Visual Programming Lab, Spring 2026
            </p>
        </div>
    </div>
</div>
