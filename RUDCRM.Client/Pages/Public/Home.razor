@page "/"
@layout RUDCRM.Client.Layout.MainLayout

<div class="hero-section">
    <div class="container position-relative" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="hero-title fade-in-up">
                    Manage Relationships<br />
                    <span class="gradient-text">Understand Growth</span>
                </h1>
                <p class="hero-subtitle fade-in-up delay-1">
                    RUD-CRM helps small businesses manage customers, leads, invoices, and tasks
                    — all in one powerful, modern platform.
                </p>
                <div class="d-flex gap-3 fade-in-up delay-2">
                    <a href="/register" class="btn btn-lg px-4 py-2" style="background:var(--rud-primary);color:#fff;border-radius:12px;font-weight:600;">
                        Get Started <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                    <a href="/about" class="btn btn-lg btn-outline-light px-4 py-2" style="border-radius:12px;font-weight:600;">
                        Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3 fade-in-up delay-3">
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon" style="background:rgba(99,102,241,.2);color:#818cf8;">
                                <i class="bi bi-people-fill"></i>
                            </div>
                            <h5 style="font-weight:700;font-size:1rem;">Customer Management</h5>
                            <p style="font-size:.85rem;opacity:.7;margin:0;">Track and manage all your customer relationships effectively.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon" style="background:rgba(14,165,233,.2);color:#38bdf8;">
                                <i class="bi bi-funnel-fill"></i>
                            </div>
                            <h5 style="font-weight:700;font-size:1rem;">Lead Tracking</h5>
                            <p style="font-size:.85rem;opacity:.7;margin:0;">Convert leads into customers with smart pipeline management.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon" style="background:rgba(16,185,129,.2);color:#34d399;">
                                <i class="bi bi-receipt"></i>
                            </div>
                            <h5 style="font-weight:700;font-size:1rem;">Invoicing</h5>
                            <p style="font-size:.85rem;opacity:.7;margin:0;">Create invoices, track payments, and manage your revenue.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon" style="background:rgba(245,158,11,.2);color:#fbbf24;">
                                <i class="bi bi-bar-chart-fill"></i>
                            </div>
                            <h5 style="font-weight:700;font-size:1rem;">Analytics</h5>
                            <p style="font-size:.85rem;opacity:.7;margin:0;">Real-time charts and insights to drive business decisions.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
