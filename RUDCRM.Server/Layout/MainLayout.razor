@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject IJSRuntime JS
@inject NotificationService NotifService

<AuthorizeView>
    <Authorized>
        <div class="app-container">
            <NavMenu />
            <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
            <div class="main-content">
                <div class="topbar">
                    <div class="topbar-left">
                        <button class="btn-theme-toggle d-md-none" @onclick="ToggleSidebar">
                            <i class="bi bi-list"></i>
                        </button>
                        <span class="topbar-title">@GetPageTitle()</span>
                    </div>
                    <div class="topbar-right">
                        <button class="btn-theme-toggle" @onclick="ToggleTheme" title="Toggle Theme">
                            <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
                        </button>
                        <div class="notification-badge">
                            <a href="/notifications" class="btn-theme-toggle" title="Notifications">
                                <i class="bi bi-bell"></i>
                            </a>
                            @if (_unreadCount > 0)
                            {
                                <span class="badge bg-danger">@_unreadCount</span>
                            }
                        </div>
                        <div class="dropdown">
                            <div class="user-menu" data-bs-toggle="dropdown">
                                <div class="user-avatar">@GetInitials()</div>
                                <span class="d-none d-md-inline" style="font-weight:600;font-size:.9rem;">@context.User.Identity?.Name</span>
                                <i class="bi bi-chevron-down" style="font-size:.7rem;"></i>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" href="#" @onclick="Logout" @onclick:preventDefault><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="content-area">
                    @Body
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _isDark;
    private int _unreadCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeManager.get");
            _isDark = theme == "dark";
            try { _unreadCount = await NotifService.GetUnreadCountAsync(); } catch { }
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var theme = await JS.InvokeAsync<string>("themeManager.toggle");
        _isDark = theme == "dark";
    }

    private async Task ToggleSidebar() => await JS.InvokeVoidAsync("rudInterop.toggleSidebar");
    private async Task CloseSidebar() => await JS.InvokeVoidAsync("rudInterop.closeSidebar");

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

    private string GetInitials()
    {
        var name = "U";
        // Try to extract from claims
        return name.Length > 0 ? name[0].ToString().ToUpper() : "U";
    }

    private string GetPageTitle()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        return uri switch
        {
            "" or "/" => "Dashboard",
            "dashboard" => "Dashboard",
            "customers" => "Customers",
            "leads" => "Leads",
            "appointments" => "Appointments",
            "invoices" => "Invoices",
            "payments" => "Payments",
            "tasks" => "Tasks",
            "notifications" => "Notifications",
            "file-uploads" => "File Uploads",
            "profile" => "Profile",
            "user-management" => "User Management",
            "announcements" => "Announcements",
            _ => "RUD-CRM"
        };
    }
}
