@page "/invoices"
@attribute [Authorize]
@inject InvoiceService InvSvc
@inject CustomerService CustSvc
@inject IJSRuntime JS

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-receipt me-2" style="color:var(--rud-success);"></i>Invoices</h4>
    <button class="btn btn-rud btn-rud-primary" @onclick="ShowAdd"><i class="bi bi-plus-lg me-1"></i>New Invoice</button>
</div>
@if(_loading){<LoadingSpinner/>}else{
<div class="data-card"><div class="data-card-body" style="overflow-x:auto;">
<table class="table-rud"><thead><tr><th>Invoice #</th><th>Customer</th><th>Amount</th><th>Status</th><th>Due Date</th><th>Paid</th><th>Actions</th></tr></thead>
<tbody>@foreach(var i in _items){
<tr><td style="font-weight:700;">@i.InvoiceNumber</td><td>@(i.CustomerName??"—")</td>
<td style="font-weight:600;">$@i.TotalAmount.ToString("N2")</td>
<td><span class="badge-status badge-@i.Status.ToLower()">@i.Status</span></td>
<td style="font-size:.85rem;">@i.DueDate.ToString("MMM dd, yyyy")</td>
<td style="font-weight:600;color:var(--rud-success);">$@i.TotalPaid.ToString("N2")</td>
<td><button class="btn btn-rud btn-rud-outline btn-rud-sm me-1" @onclick="()=>ShowEdit(i)"><i class="bi bi-pencil"></i></button>
<button class="btn btn-rud btn-rud-danger btn-rud-sm" @onclick="()=>{_del=i;_showDel=true;}"><i class="bi bi-trash"></i></button></td></tr>}
@if(!_items.Any()){<tr><td colspan="7" class="empty-state"><i class="bi bi-receipt"></i><p>No invoices</p></td></tr>}
</tbody></table></div></div>}

@if(_showModal){
<div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);"><div class="modal-dialog modal-dialog-centered"><div class="modal-content">
<div class="modal-header"><h5 class="modal-title">@(_isEdit?"Edit":"New") Invoice</h5><button class="btn-close" @onclick="()=>_showModal=false"></button></div>
<EditForm Model="_form" OnValidSubmit="Save"><DataAnnotationsValidator /><div class="modal-body"><div class="row g-3">
<div class="col-md-6"><label class="form-label">Invoice Number *</label><InputText @bind-Value="_form.InvoiceNumber" class="form-control"/></div>
<div class="col-md-6"><label class="form-label">Customer *</label><InputSelect @bind-Value="_form.CustomerId" class="form-select">
@foreach(var c in _customers){<option value="@c.Id">@c.FirstName @c.LastName</option>}</InputSelect></div>
<div class="col-md-4"><label class="form-label">Amount ($) *</label><InputNumber @bind-Value="_form.TotalAmount" class="form-control"/></div>
<div class="col-md-4"><label class="form-label">Issue Date</label><InputDate @bind-Value="_form.IssueDate" class="form-control"/></div>
<div class="col-md-4"><label class="form-label">Due Date</label><InputDate @bind-Value="_form.DueDate" class="form-control"/></div>
<div class="col-md-6"><label class="form-label">Status</label><InputSelect @bind-Value="_form.Status" class="form-select">
@foreach(var s in new[]{"Draft","Sent","Paid","Overdue","Cancelled"}){<option value="@s">@s</option>}</InputSelect></div>
<div class="col-12"><label class="form-label">Notes</label><InputTextArea @bind-Value="_form.Notes" class="form-control" rows="2"/></div>
</div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" @onclick="()=>_showModal=false">Cancel</button>
<button type="submit" class="btn btn-rud btn-rud-primary">@(_isEdit?"Update":"Create")</button></div></EditForm></div></div></div>}

<ConfirmDialog IsVisible="_showDel" Title="Delete Invoice" Message="@($"Delete {_del?.InvoiceNumber}?")" OnConfirm="Delete" OnCancel="()=>_showDel=false"/>

@code{
    List<InvoiceDto> _items=new();List<CustomerDto> _customers=new();InvoiceDto _form=new();InvoiceDto? _del;
    bool _loading=true,_showModal,_isEdit,_showDel;
    protected override async Task OnInitializedAsync(){_items=await InvSvc.GetAllAsync();_customers=await CustSvc.GetAllAsync();_loading=false;}
    void ShowAdd(){_form=new(){InvoiceNumber=$"INV-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(100,999)}",IssueDate=DateTime.Now,DueDate=DateTime.Now.AddDays(30)};_isEdit=false;_showModal=true;}
    void ShowEdit(InvoiceDto i){_form=new(){Id=i.Id,InvoiceNumber=i.InvoiceNumber,CustomerId=i.CustomerId,TotalAmount=i.TotalAmount,IssueDate=i.IssueDate,DueDate=i.DueDate,Status=i.Status,Notes=i.Notes};_isEdit=true;_showModal=true;}
    async Task Save(){bool ok=_isEdit?await InvSvc.UpdateAsync(_form.Id,_form):await InvSvc.CreateAsync(_form);
        if(ok){await JS.InvokeVoidAsync("rudInterop.showToast",_isEdit?"Updated!":"Created!","success");_showModal=false;_items=await InvSvc.GetAllAsync();}
        else await JS.InvokeVoidAsync("rudInterop.showToast","Failed.","error");}
    async Task Delete(){if(_del!=null){await InvSvc.DeleteAsync(_del.Id);_showDel=false;_items=await InvSvc.GetAllAsync();await JS.InvokeVoidAsync("rudInterop.showToast","Deleted.","success");}}
}
