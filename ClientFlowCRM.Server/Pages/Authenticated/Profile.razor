@page "/profile"
@attribute [Authorize]
@inject AuthService AuthSvc
@inject IJSRuntime JS

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-person-circle me-2" style="color:var(--rud-primary);"></i>My Profile</h4>
</div>

@if(_loading){<LoadingSpinner/>}else if(_user!=null){
<div class="row g-4">
    <div class="col-lg-4">
        <div class="data-card" style="text-align:center;padding:2rem;">
            <div class="user-avatar mx-auto mb-3" style="width:80px;height:80px;font-size:2rem;">@_user.FullName[0]</div>
            <h5 style="font-weight:700;">@_user.FullName</h5>
            <p style="color:var(--rud-text-muted);margin-bottom:.5rem;">@_user.Email</p>
            <span class="badge-status badge-qualified">@_user.Role</span>
            <p class="mt-3" style="font-size:.8rem;color:var(--rud-text-muted);">Member since @_user.CreatedAt.ToString("MMMM yyyy")</p>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="data-card mb-4">
            <div class="data-card-header"><span class="data-card-title">Edit Profile</span></div>
            <div style="padding:1.5rem;">
                <EditForm Model="_profileForm" OnValidSubmit="UpdateProfile">
                    <DataAnnotationsValidator/>
                    <div class="mb-3"><label class="form-label">Full Name</label>
                    <InputText @bind-Value="_profileForm.FullName" class="form-control"/></div>
                    <button type="submit" class="btn btn-rud btn-rud-primary">Update Profile</button>
                </EditForm>
            </div>
        </div>
        <div class="data-card">
            <div class="data-card-header"><span class="data-card-title">Change Password</span></div>
            <div style="padding:1.5rem;">
                <EditForm Model="_pwForm" OnValidSubmit="ChangePassword">
                    <DataAnnotationsValidator/>
                    <div class="mb-3"><label class="form-label">Current Password</label>
                    <InputText @bind-Value="_pwForm.CurrentPassword" type="password" class="form-control"/></div>
                    <div class="mb-3"><label class="form-label">New Password</label>
                    <InputText @bind-Value="_pwForm.NewPassword" type="password" class="form-control"/></div>
                    <div class="mb-3"><label class="form-label">Confirm New Password</label>
                    <InputText @bind-Value="_pwForm.ConfirmNewPassword" type="password" class="form-control"/></div>
                    <button type="submit" class="btn btn-rud btn-rud-primary">Change Password</button>
                </EditForm>
            </div>
        </div>
    </div>
</div>}

@code{
    UserDto? _user;UpdateProfileDto _profileForm=new();ChangePasswordDto _pwForm=new();bool _loading=true;
    protected override async Task OnInitializedAsync(){_user=await AuthSvc.GetProfileAsync();if(_user!=null)_profileForm.FullName=_user.FullName;_loading=false;}
    async Task UpdateProfile(){var ok=await AuthSvc.UpdateProfileAsync(_profileForm);await JS.InvokeVoidAsync("rudInterop.showToast",ok?"Profile updated!":"Failed.","success");}
    async Task ChangePassword(){var r=await AuthSvc.ChangePasswordAsync(_pwForm);await JS.InvokeVoidAsync("rudInterop.showToast",r.Message,r.Success?"success":"error");if(r.Success)_pwForm=new();}
}
