@page "/file-uploads"
@attribute [Authorize]
@inject FileUploadService FileSvc
@inject CustomerService CustSvc
@inject IJSRuntime JS

<div class="page-header">
    <h4 class="page-title"><i class="bi bi-cloud-upload-fill me-2" style="color:var(--rud-info);"></i>File Uploads</h4>
</div>

<!-- Upload Form -->
<div class="data-card mb-4">
    <div class="data-card-header"><span class="data-card-title">Upload Document</span></div>
    <div class="data-card-body" style="padding:1.5rem;">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Select File</label>
                <InputFile OnChange="OnFileSelected" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.txt,.csv" />
                <small class="text-muted">Max 10 MB · PDF, DOC, XLS, Images, TXT, CSV</small>
            </div>
            <div class="col-md-4">
                <label class="form-label">Associate with Customer (optional)</label>
                <select class="form-select" @onchange="OnCustomerSelect">
                    <option value="">— None —</option>
                    @foreach(var c in _customers){<option value="@c.Id">@c.FirstName @c.LastName</option>}
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-rud btn-rud-primary w-100" @onclick="Upload" disabled="@(_uploading || _selectedFile == null)">
                    @if(_uploading){<span class="spinner-border spinner-border-sm me-1"></span>}
                    <i class="bi bi-upload me-1"></i>Upload
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Documents List -->
@if(_loading){<LoadingSpinner/>}else{
<div class="data-card"><div class="data-card-body" style="overflow-x:auto;">
<table class="table-rud"><thead><tr><th>File Name</th><th>Type</th><th>Size</th><th>Customer</th><th>Uploaded</th><th>Actions</th></tr></thead>
<tbody>@foreach(var d in _docs){
<tr><td style="font-weight:600;"><i class="bi bi-file-earmark me-1"></i>@d.OriginalFileName</td>
<td><span class="badge-status badge-contacted">@d.ContentType.Split('/').Last()</span></td>
<td>@FormatSize(d.FileSize)</td>
<td>@(d.CustomerName??"—")</td>
<td style="font-size:.85rem;">@d.UploadedAt.ToString("MMM dd, yyyy")</td>
<td><a href="api/fileupload/download/@d.Id" class="btn btn-rud btn-rud-outline btn-rud-sm me-1" target="_blank"><i class="bi bi-download"></i></a>
<button class="btn btn-rud btn-rud-danger btn-rud-sm" @onclick="()=>DeleteFile(d.Id)"><i class="bi bi-trash"></i></button></td></tr>}
@if(!_docs.Any()){<tr><td colspan="6" class="empty-state"><i class="bi bi-cloud-upload"></i><p>No documents uploaded</p></td></tr>}
</tbody></table></div></div>}

@code{
    List<UploadedDocumentDto> _docs=new();List<CustomerDto> _customers=new();
    IBrowserFile? _selectedFile; int? _selectedCustomerId;
    bool _loading=true,_uploading;

    protected override async Task OnInitializedAsync(){_docs=await FileSvc.GetAllAsync();_customers=await CustSvc.GetAllAsync();_loading=false;}
    void OnFileSelected(InputFileChangeEventArgs e){_selectedFile=e.File;}
    void OnCustomerSelect(ChangeEventArgs e){_selectedCustomerId=int.TryParse(e.Value?.ToString(),out var id)?id:null;}

    async Task Upload(){
        if(_selectedFile==null)return;_uploading=true;
        var content=new MultipartFormDataContent();
        var stream=_selectedFile.OpenReadStream(10*1024*1024);
        content.Add(new StreamContent(stream),  "file",_selectedFile.Name);
        if(_selectedCustomerId.HasValue)content.Add(new StringContent(_selectedCustomerId.Value.ToString()),"customerId");
        var ok=await FileSvc.UploadAsync(content);
        if(ok){await JS.InvokeVoidAsync("rudInterop.showToast","File uploaded!","success");_docs=await FileSvc.GetAllAsync();_selectedFile=null;}
        else await JS.InvokeVoidAsync("rudInterop.showToast","Upload failed.","error");
        _uploading=false;
    }

    async Task DeleteFile(int id){await FileSvc.DeleteAsync(id);_docs=await FileSvc.GetAllAsync();await JS.InvokeVoidAsync("rudInterop.showToast","Deleted.","success");}

    string FormatSize(long bytes){
        if(bytes<1024)return $"{bytes} B";if(bytes<1048576)return $"{bytes/1024.0:F1} KB";return $"{bytes/1048576.0:F1} MB";}
}
